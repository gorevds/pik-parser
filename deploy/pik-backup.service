[Unit]
Description=Daily backup of pik.db (sqlite .backup + gzip + 14d rotation)
After=network.target

[Service]
Type=oneshot
User=pik
Group=pik
WorkingDirectory=/opt/pik
Environment=TZ=Europe/Moscow
# Скрипт идёт из репо, install.sh синхронизирует его в /opt/pik/deploy/.
ExecStart=/bin/bash /opt/pik/deploy/backup.sh
StandardOutput=journal
StandardError=journal
